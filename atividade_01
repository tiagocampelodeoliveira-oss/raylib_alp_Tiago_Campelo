#include "raylib.h"

int main()
{
    float posX = -100; 
    float posY = -100; 
    
    Texture2D sprite;
    Texture2D sprite2;

    InitWindow(800, 450, "basic window");

    sprite = LoadTexture("inimigo.png");
    sprite2 = LoadTexture("feliz.png");

    while (!WindowShouldClose())
    {
        posX += GetFrameTime() * 500;
        posY += GetFrameTime() * 500;
        
        if (posX > 800)
        {
            posX = -500;
        }
        
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(sprite, posX, 20, WHITE);
        DrawTexture(sprite2, posX, 50, WHITE);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
