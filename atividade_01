#include "raylib.h"

int main()
{
    InitWindow(800, 450, "basic window");

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawRectangle(100, 100, 100, 100, RED);
        DrawRectangle(125, 125, 125, 125, GREEN);
        DrawRectangle(150, 150, 150, 150, YELLOW);
       
       EndDrawing();
    }

    CloseWindow();

    return 0;
}
