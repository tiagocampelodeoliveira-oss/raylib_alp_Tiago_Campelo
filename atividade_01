#include "raylib.h"

int main()
{
    Texture2D sprite;   // Vou ter uma imagem chamada sprite
    Texture2D sprite2; 
    
    InitWindow(800, 450, "basic window");

    sprite = LoadTexture("inimigo.png");   // Carregue a imagem sprite.png para usar no jogo
    sprite2 = LoadTexture("feliz.png");
    
    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(sprite, 15, 50, WHITE);
        DrawTexture(sprite2, 50, 25, WHITE);
        
        EndDrawing();
    }

    CloseWindow();

    return 0;
}
